---
import { AGENT_STATUS } from "../scripts/AgentStatus";

const {
	initialStatus = AGENT_STATUS.IDLE,
} = Astro.props;
---

<section
	class="code-panel llm-status-panel"
	data-running="false"
>
	<div class="code-panel-header">
		<div class="llm-status-group">
	        <span class="llm-status-dot" id="llm-status-dot" data-state={initialStatus} aria-hidden="true"></span>
	        <span class="llm-status-text" id="llm-status-text">{initialStatus}</span>
		</div>
	</div>

	<div class="llm-output" id="llm-output">
		<pre class="code-surface llm-output-surface"><code id="llm-output-text" class="hljs language-javascript"></code><span class="llm-output-cursor" aria-hidden="true"></span></pre>
	</div>
</section>

<script>
	import { AGENT_STATUS } from "../scripts/AgentStatus";
	import { AgentStatusUpdater } from "../scripts/AgentStatusUpdater";

	const LLM_STATUS_KEY = "deobfuscator.llm.status";
	const LLM_OUTPUT_KEY = "deobfuscator.llm.output";
	const INITIAL_OUTPUT = "Agent log will appear here.";

	const statusDotElement = document.getElementById("llm-status-dot");
	const statusTextElement = document.getElementById("llm-status-text");
	const outputTextElement = document.getElementById("llm-output-text");
	const outputSurface = document.querySelector<HTMLElement>(".llm-output-surface");
	const panelElement = document.querySelector(".llm-status-panel");

	const isScrolledToBottom = () => {
		if (!outputSurface) return true;
		return outputSurface.scrollHeight - outputSurface.scrollTop - outputSurface.clientHeight < 4;
	};

	const applyStatus = (status: string, output: string) => {
		const statusValue = status || AGENT_STATUS.IDLE;
		if (statusTextElement)
			statusTextElement.textContent = statusValue;
		if (statusDotElement)
			statusDotElement.setAttribute("data-state", statusValue);
		if (panelElement)
			panelElement.setAttribute("data-running", (statusValue === AGENT_STATUS.RUNNING || statusValue === AGENT_STATUS.WARNING) ? "true" : "false");
		if (outputTextElement && typeof output === "string") {
			const atBottom = isScrolledToBottom();
			outputTextElement.innerHTML += (output || "No output provided.") + '\n';
			if (atBottom && outputSurface)
				outputSurface.scrollTop = outputSurface.scrollHeight;
		}
	};

	const clearStatusAndLog = () => {
		sessionStorage.removeItem(LLM_STATUS_KEY);
		sessionStorage.removeItem(LLM_OUTPUT_KEY);
		if (outputTextElement)
			outputTextElement.textContent = "";
	};

	applyStatus(AGENT_STATUS.IDLE, INITIAL_OUTPUT);

	window.addEventListener(AgentStatusUpdater.eventName, (event) => {
		const detail = event && (event as CustomEvent).detail ? (event as CustomEvent).detail : {};
		const nextStatus = typeof detail.status === "string" ? detail.status : AGENT_STATUS.IDLE;
		const nextOutput = typeof detail.output === "string" ? detail.output : "";

		if (nextStatus === AGENT_STATUS.CLEAR) {
			clearStatusAndLog();
		} else {
			sessionStorage.setItem(LLM_STATUS_KEY, nextStatus);
			if (typeof detail.output === "string")
				sessionStorage.setItem(LLM_OUTPUT_KEY, nextOutput);
			applyStatus(nextStatus, typeof detail.output === "string" ? nextOutput : "");
		}
	});
</script>
